<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<CodeBlocks_project_file>
<FileVersion major="1" minor="6" />
<Project>
<Option title="AC82N_gp_mcu" />
<Option compiler="pi32_lto_compiler" />
<Build>
<Target title="Release">
<Option output="cpu/cd09/tools/sdk.elf" prefix_auto="0" extension_auto="0" />
<Option object_output="obj/Release/" />
<Option type="1" />
<Option compiler="pi32_lto_compiler" />
<Compiler>
<Add option="-integrated-as" />
<Add option="-g" />
<Add option="-O0" />
<Add option="-flto" />
<Add option="-Os" />
<Add option="-fallow-pointer-null" />
<Add option="-Wincompatible-pointer-types" />
<Add option="-Wundef" />
<Add option="-Wformat" />
<Add option="-nostrictpi32" />
<Add option="-fprefer-gnu-section" />
<Add option="-Wframe-larger-than=256" />
<Add option="-Wuninitialized" />
<Add option="-Wno-invalid-noreturn" />
<Add option="-Wno-shift-negative-value" />
<Add option="-fms-extensions" />
<Add option="-fdiscrete-bitfield-abi" />
<Add option="-DCONFIG_RELEASE_ENABLE" />
<Add option="-DCONFIG_CPU_CD09" />
<Add option="-DCONFIG_CBUF_IN_MASKROM" />
<Add option="-D__GCC_PI32_LTO__" />
<Add directory="include_lib" />
<Add directory="include_lib/driver" />
<Add directory="include_lib/driver/device" />
<Add directory="include_lib/driver/cpu" />
<Add directory="include_lib/driver/cpu/cd09" />
<Add directory="include_lib/driver/cpu/periph" />
<Add directory="include_lib/system" />
<Add directory="include_lib/system/generic" />
<Add directory="include_lib/system/device" />
<Add directory="include_lib/system/fs" />
<Add directory="include_lib/system/ui" />
<Add directory="include_lib/system/math/cpu/cd09" />
<Add directory="apps/common" />
<Add directory="apps/common/device/key" />
<Add directory="apps/common/eeprom" />
<Add directory="apps/common/iic_soft" />
<Add directory="apps/gp_mcu/include" />
<Add directory="cpu/cd09" />
<Add directory="apps/common/cJSON" />
<Add directory="apps/common/lcd" />
<Add directory="apps/common/font" />
<Add directory="apps/common/ui/resource" />
<Add directory="apps/common/ui_platform" />
<Add directory="apps/common/ui_platform/core" />
<Add directory="include_lib/ui_platform" />
<Add directory="include_lib/update" />
<Add directory="include_lib/update/code_v2" />
<Add directory="apps/common/device" />
<Add directory="apps/common/device/usb" />
<Add directory="apps/common/device/usb/device" />
<Add directory="apps/common/device/usb/host" />
</Compiler>
<Linker>
<Add option="--plugin-opt=-inline-threshold=5" />
<Add option="--plugin-opt=save-temps" />
<Add option="--plugin-opt=-inline-normal-into-special-section=true" />
<Add option="--plugin-opt=-dont-used-symbol-list=malloc,free,sprintf,printf,puts,putchar" />
<Add option="--plugin-opt=-mattr=+no-constpool" />
<Add option="--plugin-opt=-warn-stack-size=256" />
<Add option="--sort-common" />
<Add option="--start-group" />
<Add option="cpu/cd09/liba/system.a" />
<Add option="cpu/cd09/liba/cpu.a" />
<Add option="cpu/cd09/liba/ump3_dec_lib.a" />
<Add option="cpu/cd09/liba/ui_platform.a" />
<Add option="cpu/cd09/liba/lib_speed_pitch.a" />
<Add option="cpu/cd09/liba/update.a" />
<Add option="--end-group" />
<Add option="-Tcpu/cd09/sdk.ld" />
<Add option="-M=cpu/cd09/tools/sdk.map" />
</Linker>
<ExtraCommands>
<Add before="$compiler $options $includes -D__LD__ -E -P cpu\cd09\sdk_ld.c -o cpu\cd09\sdk.ld" />
<Add before="$compiler $options $includes -D__LD__ -E -P cpu\cd09\tools\download_bat.c -o cpu\cd09\tools\download.bat" />
<Add before="tools\utils\fixbat.exe cpu\cd09\tools\download.bat" />
<Add before="$compiler $options $includes -D__LD__ -E -P cpu\cd09\tools\download_sh.c -o cpu\cd09\tools\download.sh" />
<Add before="$compiler $options $includes -D__LD__ -E -P cpu\cd09\tools\isd_config_rule.c -o cpu\cd09\tools\isd_config.ini" />
<Mode before="always" />
<Add after="cpu\cd09\tools\download.bat sdk" />
<Mode after="always" />
</ExtraCommands>
</Target>
</Build>
